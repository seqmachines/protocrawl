# Database
PROTOCLAW_DATABASE_URL=postgresql+asyncpg://protoclaw:protoclaw@localhost:5432/protoclaw

# Google Cloud
PROTOCLAW_GCP_PROJECT=your-gcp-project-id
PROTOCLAW_GCP_LOCATION=us-central1
PROTOCLAW_GCS_BUCKET=protoclaw-artifacts

# LLM — GLM-5 via Vertex AI Model Garden
PROTOCLAW_VERTEX_MODEL=zai-org/glm-5

# Confidence thresholds
PROTOCLAW_AUTO_PUBLISH_THRESHOLD=0.85
PROTOCLAW_REVIEW_REQUIRED_THRESHOLD=0.60

# API
PROTOCLAW_API_HOST=0.0.0.0
PROTOCLAW_API_PORT=8000
